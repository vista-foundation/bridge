# VISTA Bridge Configuration Template
# Copy this content to a .env file in the root directory and populate with your actual values

# Source Network (where deposits are watched)
SOURCE_NETWORK_NAME=preproduction
SOURCE_UTXORPC_URL=https://preprod.utxorpc-v0.demeter.run
SOURCE_UTXORPC_API_KEY=your_demeter_api_key_here
SOURCE_LUCID_PROVIDER=https://preprod.koios.rest/api/v1
SOURCE_LUCID_NETWORK=Preproduction
# Comma-separated list of addresses to watch for deposits
SOURCE_DEPOSIT_ADDRESSES=addr_test1qpnueplse6f4d55eumh7f3tzp3wx882xk7qs6ydxtynrfsw89vzfjf0v4yca056el40n7pr568rdls6lp6eu0dwek9nqku88yp

# Destination Network (where mirror transactions are sent)
DEST_NETWORK_NAME=preview  
DEST_UTXORPC_URL=https://preview.utxorpc-v0.demeter.run
DEST_UTXORPC_API_KEY=your_demeter_api_key_here
DEST_LUCID_PROVIDER=https://preview.koios.rest/api/v1
DEST_LUCID_NETWORK=Preview
# Comma-separated list of sender addresses for mirror transactions
DEST_SENDER_ADDRESSES=addr_test1qpg5fj3gsmt673lpxlpzhum6mrw2z0hyk3u455swep39zdt6yr3r556e70k6uvrj8jyey6jwnaeamenujatxuqs50ljq2mq4xl

# Bridge Configuration
BRIDGE_ALLOWED_ASSETS=ADA
BRIDGE_MIN_DEPOSIT_AMOUNT=2000000
BRIDGE_MAX_TRANSFER_AMOUNT=100000000000
BRIDGE_FEE_AMOUNT=1000000

# Security Settings
SECURITY_REQUIRED_CONFIRMATIONS=5
SECURITY_RETRY_ATTEMPTS=3
SECURITY_RETRY_DELAY_MS=5000

# gRPC Service Ports
GRPC_INDEXER_PORT=50051
GRPC_RELAYER_PORT=50052
GRPC_MIRROR_PORT=50053

# HTTP API
API_PORT=3001

# Note: Get your Demeter API keys from https://demeter.run
# Each network needs its own API key and endpoint 